FROM golang:1.25 AS builder

WORKDIR /src
COPY go.mod go.sum ./
RUN go mod download

COPY . .
RUN CGO_ENABLED=0 GOOS=linux go build -o /bin/whatsapp-bridge .

FROM gcr.io/distroless/base-debian12

WORKDIR /app
COPY --from=builder /bin/whatsapp-bridge /app/whatsapp-bridge

EXPOSE 8080

ENTRYPOINT ["/app/whatsapp-bridge"]
